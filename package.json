{
  "name": "@marcfargas/pi-tramp",
  "version": "0.2.0",
  "description": "TRAMP-like transparent remote execution for pi — tools execute remotely, pi stays local",
  "author": "Marc Fargas",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/marcfargas/pi-tramp.git"
  },
  "keywords": [
    "pi",
    "pi-package",
    "agent",
    "ssh",
    "docker",
    "remote",
    "tramp",
    "transparent-execution"
  ],
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./src/extension.ts"
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/tramp-exec.d.ts",
      "default": "./dist/tramp-exec.js"
    }
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.50.0"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src/ test/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^10.0.1",
    "@mariozechner/pi-coding-agent": ">=0.50.0",
    "eslint": "^10.0.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.1.4"
  }
}
